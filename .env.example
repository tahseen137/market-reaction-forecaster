AWS_SECRET_ACCESS_KEY=
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
SEC_USER_AGENT=MarketReactionForecaster/1.0 contact@example.com
FREE_SAMPLE_DELAY_HOURS=24
TRIAL_DAYS=7
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=no-reply@example.com
SENTRY_DSN=
